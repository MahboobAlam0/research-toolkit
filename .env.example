# ─── .env.example ──────────────────────────────────────────────────────────────
# Template only — contains NO real credentials.
# Copy to .env and fill in your actual values. Never commit .env to git.

# ── Required ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# Local Docker (default):
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# Qdrant Cloud (get free cluster at https://cloud.qdrant.io/):
QDRANT_URL=https://your-cluster-id.us-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Optional ───────────────────────────────────────────────────────────────────
DEFAULT_RESUME=
